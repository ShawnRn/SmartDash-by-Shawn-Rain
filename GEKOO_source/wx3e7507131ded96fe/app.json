{
  "permission": {
    "scope.userLocation": { "desc": "蓝牙使用" },
    "scope.bluetooth": { "desc": "连接设备" },
    "scope.clipboard": { "desc": "用于复制当前的数据便于使用" }
  },
  "preloadRule": {
    "pages/index/index": {
      "network": "all",
      "packages": [
        "subpackages/images",
        "subpackages/contact",
        "subpackages/product",
        "subpackages/info"
      ]
    }
  },
  "componentFramework": { "allUsed": ["exparser"], "default": "exparser" },
  "subPackages": [
    {
      "root": "subpackages/contact/",
      "pages": ["pages/contact", "pages/maptest", "query"]
    },
    {
      "root": "subpackages/product/",
      "pages": ["pages/product", "pages/description"]
    },
    {
      "root": "subpackages/info/",
      "pages": [
        "pages/faq/faq",
        "pages/firmwave/firmwave",
        "pages/version/version",
        "pages/faqlist/faqlist",
        "flowchart/flowchart",
        "battery/battery"
      ]
    },
    { "root": "subpackages/images/", "pages": ["logo/logo"] },
    { "root": "subpackages/firmwave_ae/", "pages": ["null/null"] },
    { "root": "subpackages/firmwave_cp/", "pages": ["null/null"] },
    { "root": "subpackages/firmwave_gk/", "pages": ["null/null"] },
    { "root": "subpackages/firmwave_nd/", "pages": ["null/null"] },
    { "root": "subpackages/firmwave_pd/", "pages": ["null/null"] },
    { "root": "subpackages/firmwave_ub/", "pages": ["null/null"] },
    {
      "root": "subpackages/firmwave_xm/",
      "independent": true,
      "pages": ["null/null"]
    }
  ],
  "window": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "uni-app",
    "navigationBarBackgroundColor": "#F8F8F8",
    "backgroundColor": "#F8F8F8"
  },
  "pages": [
    "pages/logo/logo",
    "pages/index/index",
    "pages/ble_debug/ble_debug",
    "pages/test/test",
    "pages/language/language",
    "pages/webview/webview",
    "subpackages/apppolicy/userAgreement/userAgreement",
    "subpackages/apppolicy/privacyPolicy/privacyPolicy"
  ]
}
