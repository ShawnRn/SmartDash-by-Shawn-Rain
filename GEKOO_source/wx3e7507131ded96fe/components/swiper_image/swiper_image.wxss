.screen-swiper {
  min-height: 480rpx;
  position: relative;
}
.swiper-item-container {
  height: 100%;
  position: relative;
  width: 100%;
}
.carousel-caption {
  bottom: 0;
  left: 0;
  padding: 30rpx 40rpx;
  position: absolute;
  right: 0;
  transition: all 0.3s ease;
  z-index: 10;
}
.caption-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}
.caption-desc {
  font-size: 24rpx;
  line-height: 1.5;
  opacity: 0.9;
}
.card-swiper.tower-item {
  margin-left: calc(var(--left) * 100rpx - 150rpx);
  transform: scale(calc(0.5 + var(--index) / 10));
  z-index: var(--index);
}
