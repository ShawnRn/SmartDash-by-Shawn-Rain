.template-planet {
  background-color: #e6edff;
  color: #fff;
  height: 100vh;
  margin: 0;
  overflow-y: auto;
  width: 100%;
}
.text-container {
  color: #7fffd4;
  font-size: 60rpx;
  height: 100rpx;
  width: 100rpx;
}
.input-row {
  align-items: center;
  display: -webkit-flex;
  display: flex;
}
.input-with-border {
  border: 1px solid #4169e1;
  margin: 0 5px;
  padding: 5px;
}
.privacy-policy-popup {
  align-items: center;
  background-color: rgba(0, 0, 0, 0.5);
  display: -webkit-flex;
  display: flex;
  height: 100%;
  justify-content: center;
  left: 0;
  position: fixed;
  top: 0;
  width: 100%;
  z-index: 111;
}
.popup-content {
  background-color: #fff;
  border-radius: 10px;
  max-width: 500px;
  padding: 20px;
  width: 80%;
}
.popup-header {
  margin-bottom: 10px;
  text-align: center;
}
.popup-title {
  color: #000;
  font-size: 20px;
  font-weight: 700;
}
.popup-body {
  margin-bottom: 10px;
}
.popup-text {
  color: #000;
  line-height: 1.6;
}
.link {
  display: inline;
}
.link,
.privacy-policy-link {
  color: blue;
  text-decoration: underline;
}
.popup-footer {
  display: -webkit-flex;
  display: flex;
  justify-content: flex-end;
}
.reject-button {
  background-color: #ccc;
  margin-right: 10px;
}
.accept-button,
.reject-button {
  border: none;
  border-radius: 5px;
  color: #fff;
  padding: 8px 16px;
}
.accept-button {
  background-color: green;
}
